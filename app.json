{
  "expo": {
    "name": "ECHO iPhone",
    "slug": "echo-ios",
    "scheme": "echo",
    "version": "0.5.0",
    "icon": "./docs/app-icon.png",
    "platforms": [
      "ios"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.echo.next.ios",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ECHO iPhone uses the camera to scan ECHO pairing QR codes.",
        "NSLocalNetworkUsageDescription": "ECHO iPhone connects to ECHO NEXT on your local network for playback control and library browsing.",
        "NSBonjourServices": [
          "_echo-link._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "plugins": [
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true,
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-image",
      "expo-secure-store"
    ]
  }
}
